{"file":"ChatInput.vue2.mjs","mappings":";;;;;;;;;;;;;AAoCA,UAAM,QAAQ;AAId,UAAM,OAAO;AAEP,UAAA,YAAY,IAAI,EAAE;AAElB,UAAA,UAAU,SAAS,MAAM;AAC7B,aAAO,UAAU,MAAM,KAAA,EAAO,SAAS,KAAK,CAAC,MAAM;AAAA,IAAA,CACpD;AAED,UAAM,cAAc,MAAM;AACxB,UAAI,QAAQ,OAAO;AACjB,aAAK,QAAQ,UAAU,MAAM,KAAA,CAAM;AACnC,kBAAU,QAAQ;AAAA,MAAA;AAAA,IAEtB;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;","names":[],"sources":["../../../../components/ChatInput.vue"],"sourcesContent":["<template>\n  <div class=\"p-4 bg-gray-900 fixed bottom-0 left-0 right-0\">\n    <div class=\"max-w-5xl mx-auto\">\n      <InputGroup class=\"mb-5\">\n        <InputText\n          placeholder=\"Ask anything...\"\n          :disabled=\"disabled\"\n          v-model=\"inputText\"\n          class=\"text-white\"\n          @keypress.enter=\"sendMessage\"\n        />\n        <Button icon=\"pi pi-send\" @click=\"sendMessage\" :disabled=\"!canSend\" />\n      </InputGroup>\n\n      <!-- Footer text -->\n      <p class=\"text-xs text-gray-500 text-center mt-2\">\n        This parody website was not requested or authorized by any candidate or\n        candidate's committee. Paid for by\n        <a target=\"_blank\" href=\"https://www.papnj.com\">People Are People LLC</a\n        >, 971 US Highway 202N #8014, Branchburg, NJ 08876.\n      </p>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed } from 'vue'\n\ninterface Emits {\n  (e: 'send', message: string): void\n}\n\ninterface Props {\n  disabled?: boolean\n}\n\nconst props = withDefaults(defineProps<Props>(), {\n  disabled: false\n})\n\nconst emit = defineEmits<Emits>()\n\nconst inputText = ref('')\n\nconst canSend = computed(() => {\n  return inputText.value.trim().length > 0 && !props.disabled\n})\n\nconst sendMessage = () => {\n  if (canSend.value) {\n    emit('send', inputText.value.trim())\n    inputText.value = ''\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.p-inputtext {\n  border-top-left-radius: var(--border-radius) !important;\n  border-bottom-left-radius: var(--border-radius) !important;\n  background-color: rgb(31 41 55 / var(--tw-bg-opacity, 1)) !important;\n  border: none;\n  padding: 1rem !important;\n  &::placeholder {\n    color: rgba(255, 255, 255, 0.7) !important;\n  }\n}\n.p-inputgroup button {\n  border-top-right-radius: var(--border-radius) !important;\n  border-bottom-right-radius: var(--border-radius) !important;\n  padding-left: 1.5rem !important;\n  padding-right: 1.75rem !important;\n}\n\n/* Ensure the input container stays above keyboard on mobile */\n@supports (height: 100dvh) {\n  .fixed {\n    /* Use dynamic viewport height when available */\n    bottom: env(keyboard-inset-height, 0px);\n  }\n}\n\n/* Smooth transitions for keyboard animations */\n.transition-all {\n  transition-property: bottom, transform;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n}\n</style>\n"],"version":3}